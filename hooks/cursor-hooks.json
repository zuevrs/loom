{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node hooks/loom-session-start.cjs",
        "timeout": 5
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node hooks/loom-pre-llm.cjs",
        "timeout": 3
      }
    ],
    "subagentStart": [
      {
        "command": "node hooks/loom-subagent-cursor.cjs",
        "timeout": 3
      }
    ]
  }
}
