{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/loom-session-start.cjs\"",
            "commandWindows": "node \"%CLAUDE_PLUGIN_ROOT%\\hooks\\loom-session-start.cjs\"",
            "timeout": 5,
            "statusMessage": "Loading Loom context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/loom-pre-llm.cjs\"",
            "commandWindows": "node \"%CLAUDE_PLUGIN_ROOT%\\hooks\\loom-pre-llm.cjs\"",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/loom-subagent.cjs\"",
            "commandWindows": "node \"%CLAUDE_PLUGIN_ROOT%\\hooks\\loom-subagent.cjs\"",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-gate-logic.cjs\"",
            "commandWindows": "node \"%CLAUDE_PLUGIN_ROOT%\\hooks\\stop-gate-logic.cjs\"",
            "timeout": 5,
            "statusMessage": "Checking verify-before-done gate..."
          }
        ]
      }
    ]
  }
}
