#!/usr/bin/env bash
# loom: loop config drift check — validates config ↔ state ↔ safety consistency
# Exit codes: 0 healthy, 1 critical (missing files), 2 warning (drift)
# NOTE: In CI, non-zero exits fail the step. Use `|| true` or
#       `continue-on-error: true` if you want warnings to be non-blocking.
set -euo pipefail

ROOT="${1:-.}"
LOOPS_DIR="$ROOT/.loom/loops"
score=100
warnings=()
errors=()

if [ ! -d "$LOOPS_DIR" ]; then
  echo '{"score":0,"status":"no_loops","message":"No .loom/loops/ directory"}'
  exit 0
fi

for config in "$LOOPS_DIR"/*.yaml "$LOOPS_DIR"/*.yml; do
  [ -f "$config" ] || continue
  name=$(basename "$config" | sed 's/\.\(yaml\|yml\)$//')

  # Check schema_version
  schema_version=$(grep '^schema_version' "$config" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ -z "$schema_version" ]; then
    errors+=("$name: missing schema_version")
    score=$((score - 20))
  elif [ "$schema_version" != "1" ]; then
    errors+=("$name: unsupported schema_version '$schema_version' (expected 1)")
    score=$((score - 20))
  fi

  # Check mode
  mode=$(grep '^mode' "$config" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ "$mode" != "discovery" ] && [ "$mode" != "execution" ]; then
    errors+=("$name: mode must be 'discovery' or 'execution'")
    score=$((score - 15))
  fi

  # Check rollout_mode
  rollout_mode=$(grep '^rollout_mode' "$config" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ "$rollout_mode" != "report-only" ] && [ "$rollout_mode" != "assisted" ] && [ "$rollout_mode" != "unattended" ]; then
    errors+=("$name: rollout_mode must be report-only|assisted|unattended")
    score=$((score - 15))
  fi

  # Check base_branch
  base_branch=$(grep '^base_branch' "$config" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ -z "$base_branch" ]; then
    errors+=("$name: missing base_branch")
    score=$((score - 10))
  fi

  # Check trigger.type (+ cron for schedule)
  trigger_type=$(grep -A3 '^trigger' "$config" 2>/dev/null | grep 'type' | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ "$trigger_type" != "schedule" ] && [ "$trigger_type" != "manual" ]; then
    errors+=("$name: trigger.type must be schedule|manual")
    score=$((score - 15))
  fi
  if [ "$trigger_type" = "schedule" ]; then
    trigger_cron=$(grep -A3 '^trigger' "$config" 2>/dev/null | grep 'cron' | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
    if [ -z "$trigger_cron" ]; then
      errors+=("$name: trigger.type=schedule requires trigger.cron")
      score=$((score - 10))
    fi
  fi

  # Check required limits keys
  for limit_key in max_iterations max_run_minutes max_auto_actions_per_run cooldown_minutes low_acceptance_threshold; do
    if ! grep -A12 '^limits' "$config" 2>/dev/null | grep -q "$limit_key"; then
      errors+=("$name: limits.$limit_key missing")
      score=$((score - 8))
    fi
  done

  if ! grep -q '^issue_selector' "$config" 2>/dev/null; then
    errors+=("$name: missing issue_selector")
    score=$((score - 10))
  fi
  if ! grep -q '^output_target' "$config" 2>/dev/null; then
    errors+=("$name: missing output_target")
    score=$((score - 10))
  fi

  # Check safety_policy_path
  safety_path=$(grep 'safety_policy_path' "$config" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ -n "$safety_path" ]; then
    resolved="$ROOT/$safety_path"
    if [ ! -f "$resolved" ]; then
      errors+=("$name: safety_policy_path '$safety_path' not found")
      score=$((score - 30))
    fi
  else
    warnings+=("$name: no safety_policy_path defined")
    score=$((score - 10))
  fi

  # Check state_path
  state_path=$(grep 'state_path' "$config" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ -n "$state_path" ]; then
    resolved="$ROOT/$state_path"
    if [ ! -f "$resolved" ]; then
      warnings+=("$name: state_path '$state_path' not found (will be created on first run)")
      score=$((score - 5))
    fi
  fi

  # Check starter_id references a known starter
  starter_id=$(grep 'starter_id' "$config" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ -n "$starter_id" ]; then
    # Look in repo loops/ or local loops
    found=0
    for dir in "$ROOT/loops" "$(dirname "$0")/../loops"; do
      if [ -f "$dir/$starter_id.md" ]; then
        found=1
        break
      fi
    done
    if [ $found -eq 0 ]; then
      warnings+=("$name: starter_id '$starter_id' not found in loops/")
      score=$((score - 5))
    fi
  fi

  # Check human_owner is not TBD
  owner=$(grep 'human_owner' "$config" 2>/dev/null | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ -z "$owner" ] || [ "$owner" = "TBD" ] || [ "$owner" = "<name>" ]; then
    errors+=("$name: human_owner is unset or TBD")
    score=$((score - 20))
  fi

  # Check objective_gate command
  gate_cmd=$(grep -A4 '^objective_gate' "$config" 2>/dev/null | grep 'command' | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)
  if [ -z "$gate_cmd" ] || echo "$gate_cmd" | grep -q '<'; then
    warnings+=("$name: objective_gate command is placeholder or missing")
    score=$((score - 10))
  fi
done

# Cap score at 0
[ $score -lt 0 ] && score=0

# Output
echo "{"
echo "  \"score\": $score,"
if [ ${#errors[@]} -gt 0 ]; then
  echo "  \"status\": \"critical\","
else
  if [ ${#warnings[@]} -gt 0 ]; then
    echo "  \"status\": \"warning\","
  else
    echo "  \"status\": \"healthy\","
  fi
fi

if [ ${#errors[@]} -gt 0 ]; then
  echo "  \"errors\": ["
  for i in "${!errors[@]}"; do
    comma=","
    [ $i -eq $((${#errors[@]} - 1)) ] && comma=""
    echo "    \"${errors[$i]}\"$comma"
  done
  echo "  ],"
fi

if [ ${#warnings[@]} -gt 0 ]; then
  echo "  \"warnings\": ["
  for i in "${!warnings[@]}"; do
    comma=","
    [ $i -eq $((${#warnings[@]} - 1)) ] && comma=""
    echo "    \"${warnings[$i]}\"$comma"
  done
  echo "  ],"
fi

echo "  \"message\": \"Score $score/100\""
echo "}"

# Exit codes: 0 healthy, 1 critical, 2 warning
if [ ${#errors[@]} -gt 0 ]; then
  exit 1
elif [ ${#warnings[@]} -gt 0 ]; then
  exit 2
fi
exit 0
