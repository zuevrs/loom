#!/usr/bin/env bash
# loom: loop runner entrypoint (ADR-0079) — validates config and runs objective gate
# Usage: scripts/run-loop [--dry-run] [starter-id]
# Exit: 0 success | 1 loop execution failure | 2 config validation | 3 runtime/auth
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PROJECT_ROOT="${LOOM_PROJECT_ROOT:-$(pwd)}"
LOOPS_DIR="$PROJECT_ROOT/.loom/loops"
DRY_RUN=0
STARTER_ID=""

while [ $# -gt 0 ]; do
  case "$1" in
    --dry-run) DRY_RUN=1; shift ;;
    -h|--help)
      echo "Usage: scripts/run-loop [--dry-run] [starter-id]"
      exit 0
      ;;
    *)
      STARTER_ID="$1"
      shift
      ;;
  esac
done

# Kill switch — default off (ADR-0080)
if [ "${LOOM_LOOPS_ENABLED:-false}" != "true" ] && [ "$DRY_RUN" -eq 0 ]; then
  echo '{"status":"blocked","reason":"LOOM_LOOPS_ENABLED is not true"}'
  exit 3
fi

if [ ! -d "$LOOPS_DIR" ]; then
  echo '{"status":"error","reason":"No .loom/loops/ directory"}'
  exit 2
fi

configs=()
if [ -n "$STARTER_ID" ]; then
  for ext in yaml yml; do
    [ -f "$LOOPS_DIR/$STARTER_ID.$ext" ] && configs+=("$LOOPS_DIR/$STARTER_ID.$ext")
  done
  if [ ${#configs[@]} -eq 0 ]; then
    echo "{\"status\":\"error\",\"reason\":\"starter not found: $STARTER_ID\"}"
    exit 2
  fi
else
  for config in "$LOOPS_DIR"/*.yaml "$LOOPS_DIR"/*.yml; do
    [ -f "$config" ] || continue
    configs+=("$config")
  done
fi

if [ ${#configs[@]} -eq 0 ]; then
  echo '{"status":"error","reason":"No loop configs found"}'
  exit 2
fi

# Validate project configs via canary (uses PROJECT_ROOT as check root)
check_out="$(bash "$ROOT/scripts/check-loop-config" "$PROJECT_ROOT" 2>&1 || true)"
if echo "$check_out" | grep -q '"status": "unhealthy"'; then
  echo "$check_out"
  exit 2
fi

failures=0
REDACT="$ROOT/scripts/redact-output.sh"

emit() {
  echo "$1" | bash "$REDACT"
}

for config in "${configs[@]}"; do
  name="$(basename "$config")"
  name="${name%.yaml}"
  name="${name%.yml}"
  gate_cmd="$(grep -A4 '^objective_gate' "$config" 2>/dev/null | grep 'command' | head -1 | sed 's/.*: *//' | tr -d '"' | tr -d "'" || true)"

  if [ -z "$gate_cmd" ] || echo "$gate_cmd" | grep -q '<'; then
    emit "{\"starter\":\"$name\",\"status\":\"error\",\"reason\":\"objective_gate command missing or placeholder\"}"
    exit 2
  fi

  if [ "$DRY_RUN" -eq 1 ]; then
    emit "{\"starter\":\"$name\",\"status\":\"dry-run\",\"would_run\":\"$gate_cmd\"}"
    continue
  fi

  emit "Running objective gate for $name: $gate_cmd"
  if (cd "$PROJECT_ROOT" && eval "$gate_cmd" 2>&1 | bash "$REDACT"); then
    emit "{\"starter\":\"$name\",\"status\":\"pass\"}"
  else
    emit "{\"starter\":\"$name\",\"status\":\"fail\"}"
    failures=$((failures + 1))
  fi
done

if [ "$DRY_RUN" -eq 1 ]; then
  exit 0
fi

[ "$failures" -gt 0 ] && exit 1
exit 0
