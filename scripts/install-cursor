#!/usr/bin/env bash
# loom: install skills + hooks for Cursor IDE
# 1. Creates symlinks in ~/.agents/skills/ → all Loom skill directories
# 2. Installs loom hooks in ~/.cursor/hooks.json (creates file, otherwise prints manual merge hints)
# Cursor discovers skills from ~/.agents/skills/ and hooks from ~/.cursor/hooks.json.
# Exit: 0 all installed, 1 partial (some skipped), 2 preflight failure
set -euo pipefail

LOOM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$LOOM_ROOT/skills"
HOOKS_DIR="$LOOM_ROOT/hooks"
TARGET_DIR="$HOME/.agents/skills"
HOOKS_FILE="$HOME/.cursor/hooks.json"

# Preflight
if [ ! -d "$SKILLS_DIR" ]; then
  echo "ERROR: skills/ directory not found at $SKILLS_DIR" >&2
  exit 2
fi
for f in loom-session-start.cjs loom-pre-llm.cjs loom-subagent-cursor.cjs stop-gate-logic.cjs; do
  if [ ! -f "$HOOKS_DIR/$f" ]; then
    echo "ERROR: hook source missing: $HOOKS_DIR/$f" >&2
    exit 2
  fi
done
if ! command -v node >/dev/null 2>&1; then
  echo "ERROR: node not found on PATH (required for Cursor hooks)" >&2
  exit 2
fi

skipped=0

# --- Skills ---
echo "Skills:"
mkdir -p "$TARGET_DIR"

installed=0
for skill_dir in "$SKILLS_DIR"/*/; do
  [ -f "${skill_dir}SKILL.md" ] || continue
  skill_name=$(basename "$skill_dir")
  target="$TARGET_DIR/$skill_name"

  if [ -L "$target" ]; then
    existing=$(readlink "$target")
    if [ "$existing" = "$skill_dir" ] || [ "$existing" = "${skill_dir%/}" ]; then
      echo "  ✓ $skill_name (already linked)"
      installed=$((installed + 1))
      continue
    fi
    echo "  ⚠ $skill_name: symlink exists → $existing (skipping)"
    skipped=$((skipped + 1))
    continue
  fi

  if [ -e "$target" ]; then
    echo "  ⚠ $skill_name: path exists and is not a symlink (skipping)"
    skipped=$((skipped + 1))
    continue
  fi

  ln -s "${skill_dir%/}" "$target"
  echo "  ✓ $skill_name → $skill_dir"
  installed=$((installed + 1))
done

echo "  $installed skills linked"
echo ""

# --- Hooks ---
echo "Hooks:"
mkdir -p "$(dirname "$HOOKS_FILE")"

# Build the hooks entries with absolute paths
SESSION_CMD="node $HOOKS_DIR/loom-session-start.cjs"
PRELLM_CMD="node $HOOKS_DIR/loom-pre-llm.cjs"
SUBAGENT_CMD="node $HOOKS_DIR/loom-subagent-cursor.cjs"
STOP_CMD="node $HOOKS_DIR/stop-gate-logic.cjs"

if [ ! -f "$HOOKS_FILE" ]; then
  cat > "$HOOKS_FILE" << HOOKSEOF
{
  "version": 1,
  "hooks": {
    "sessionStart": [{"command": "$SESSION_CMD", "timeout": 5}],
    "beforeSubmitPrompt": [{"command": "$PRELLM_CMD", "timeout": 3}],
    "subagentStart": [{"command": "$SUBAGENT_CMD", "timeout": 3}],
    "stop": [{"command": "$STOP_CMD", "timeout": 5}]
  }
}
HOOKSEOF
  echo "  ✓ Created $HOOKS_FILE with loom hooks"
else
  # Check whether all loom hooks are present
  missing=()
  if ! grep -q "loom-session-start" "$HOOKS_FILE" 2>/dev/null; then
    missing+=("sessionStart: {\"command\": \"$SESSION_CMD\", \"timeout\": 5}")
  fi
  if ! grep -q "loom-pre-llm" "$HOOKS_FILE" 2>/dev/null; then
    missing+=("beforeSubmitPrompt: {\"command\": \"$PRELLM_CMD\", \"timeout\": 3}")
  fi
  if ! grep -q "loom-subagent-cursor" "$HOOKS_FILE" 2>/dev/null; then
    missing+=("subagentStart: {\"command\": \"$SUBAGENT_CMD\", \"timeout\": 3}")
  fi
  if ! grep -q "stop-gate-logic" "$HOOKS_FILE" 2>/dev/null; then
    missing+=("stop: {\"command\": \"$STOP_CMD\", \"timeout\": 5}")
  fi

  if [ ${#missing[@]} -eq 0 ]; then
    echo "  ✓ Loom hooks already in $HOOKS_FILE"
  else
    echo "  ⚠ $HOOKS_FILE exists. Add missing entries manually:"
    for entry in "${missing[@]}"; do
      echo "    $entry"
    done
  fi
fi

echo ""
if [ "$skipped" -gt 0 ]; then
  echo "Done ($skipped skipped). Restart Cursor to pick up changes."
  exit 1
fi
echo "Done. Restart Cursor to pick up changes."
