#!/usr/bin/env bash
# loom: structural smoke — no LLM, runs all maintainer checks
# Exit: 0 pass, 1 drift/failure, 3 execution error
set -euo pipefail

ROOT="${1:-$(cd "$(dirname "$0")/.." && pwd)}"
cd "$ROOT"

run() {
  echo "→ $*"
  "$@"
}

run node tests/hooks.test.mjs
run bash scripts/check-drift
run bash scripts/check-doc-consistency
run bash scripts/check-installers
run bash scripts/check-skill-template-contract
run bash scripts/check-template-sections

echo '{"status":"pass","message":"Structural smoke passed"}'
