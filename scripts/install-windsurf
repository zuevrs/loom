#!/usr/bin/env bash
# loom: install skills for Windsurf IDE
# Creates symlinks in ~/.codeium/windsurf/skills/ pointing to loom skill directories.
# Windsurf discovers skills from ~/.codeium/windsurf/skills/ (global) and .windsurf/skills/ (project).
set -euo pipefail

LOOM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$LOOM_ROOT/skills"
TARGET_DIR="$HOME/.codeium/windsurf/skills"

mkdir -p "$TARGET_DIR"

echo "Windsurf skills:"
installed=0
for skill_dir in "$SKILLS_DIR"/loom-*/; do
  [ -d "$skill_dir" ] || continue
  skill_name=$(basename "$skill_dir")
  target="$TARGET_DIR/$skill_name"

  if [ -L "$target" ]; then
    existing=$(readlink "$target")
    if [ "$existing" = "${skill_dir%/}" ]; then
      echo "  ✓ $skill_name (already linked)"
      installed=$((installed + 1))
      continue
    fi
    echo "  ⚠ $skill_name: symlink exists → $existing (skipping)"
    continue
  fi

  if [ -e "$target" ]; then
    echo "  ⚠ $skill_name: path exists and is not a symlink (skipping)"
    continue
  fi

  ln -s "${skill_dir%/}" "$target"
  echo "  ✓ $skill_name"
  installed=$((installed + 1))
done

echo ""
echo "Done. $installed skills linked in $TARGET_DIR"
echo "Windsurf will discover them on next Cascade session."
echo ""
echo "For project-level discipline: run loom-init to write AGENTS.md (Windsurf reads it natively)."
