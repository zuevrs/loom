#!/usr/bin/env bash
# loom: install skills for AGENTS.md-tier hosts (Cline/OpenClaw)
# Creates symlinks in ~/.agents/skills/ pointing to all Loom skill directories.
set -euo pipefail

LOOM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$LOOM_ROOT/skills"
TARGET_DIR="$HOME/.agents/skills"

mkdir -p "$TARGET_DIR"

echo "Agent skills:"
installed=0
for skill_dir in "$SKILLS_DIR"/*/; do
  [ -f "${skill_dir}SKILL.md" ] || continue
  skill_name=$(basename "$skill_dir")
  target="$TARGET_DIR/$skill_name"

  if [ -L "$target" ]; then
    existing=$(readlink "$target")
    if [ "$existing" = "$skill_dir" ] || [ "$existing" = "${skill_dir%/}" ]; then
      echo "  ✓ $skill_name (already linked)"
      installed=$((installed + 1))
      continue
    fi
    echo "  ⚠ $skill_name: symlink exists → $existing (skipping)"
    continue
  fi

  if [ -e "$target" ]; then
    echo "  ⚠ $skill_name: path exists and is not a symlink (skipping)"
    continue
  fi

  ln -s "${skill_dir%/}" "$target"
  echo "  ✓ $skill_name"
  installed=$((installed + 1))
done

echo ""
echo "Done. $installed skills linked in $TARGET_DIR"
echo "Next: run loom-init in each project to write AGENTS.md managed block."
