#!/usr/bin/env bash
# loom: docs consistency canary — validates key user-facing docs stay aligned
# Exit: 0 clean, 1 drift detected
set -euo pipefail

ROOT="${1:-$(cd "$(dirname "$0")/.." && pwd)}"
README="$ROOT/README.md"
AGENTS="$ROOT/AGENTS.md"
INIT_SKILL="$ROOT/skills/loom-init/SKILL.md"
PLAN_SKILL="$ROOT/skills/loom-plan/SKILL.md"
PRELLM_HOOK="$ROOT/hooks/loom-pre-llm.cjs"
INVARIANTS_SRC="$ROOT/hooks/invariants.cjs"
CHANGELOG="$ROOT/CHANGELOG.md"
RELEASE_DOC="$ROOT/RELEASE.md"
PKG_JSON="$ROOT/package.json"
CONTRIBUTING_DOC="$ROOT/CONTRIBUTING.md"
CHECKS_WORKFLOW="$ROOT/.github/workflows/checks.yml"

errors=()

if [ ! -f "$README" ] || [ ! -f "$AGENTS" ] || [ ! -f "$INIT_SKILL" ] || [ ! -f "$PLAN_SKILL" ] || [ ! -f "$PRELLM_HOOK" ] || [ ! -f "$INVARIANTS_SRC" ] || [ ! -f "$CHANGELOG" ] || [ ! -f "$RELEASE_DOC" ] || [ ! -f "$PKG_JSON" ] || [ ! -f "$CONTRIBUTING_DOC" ] || [ ! -f "$CHECKS_WORKFLOW" ]; then
  echo '{"status":"skip","message":"Required docs/hook files are missing"}'
  exit 0
fi

pkg_version="$(grep '\"version\"' "$PKG_JSON" 2>/dev/null | head -1 | sed 's/.*: *\"//' | sed 's/\".*//' || true)"

# README: Codex install/uninstall commands must match current CLI verbs.
if ! grep -Fq 'codex plugin marketplace add zuevrs/loom && codex plugin add loom@loom' "$README"; then
  errors+=("README Codex install command is stale")
fi
if ! grep -Fq 'codex plugin remove loom@loom && codex plugin marketplace remove loom' "$README"; then
  errors+=("README Codex uninstall command is stale")
fi
if ! grep -Fq '~/.loom/scripts/install-agents-skills' "$README"; then
  errors+=("README Cline/OpenClaw install command should use install-agents-skills")
fi
if grep -Fq 'Same as Cursor (`~/.loom/scripts/install-cursor`)' "$README"; then
  errors+=("README still points Cline/OpenClaw to install-cursor")
fi
if ! grep -Fq 'droid plugin uninstall loom' "$README"; then
  errors+=("README Droid uninstall command should use plugin uninstall")
fi
if grep -Fq 'Cline/Droid/OpenClaw' "$README"; then
  errors+=("README still groups Droid with Cline/OpenClaw uninstall path")
fi
if ! grep -Fq 'If installed via `clawhub`' "$README"; then
  errors+=("README OpenClaw uninstall should describe clawhub path")
fi
if ! grep -Fq 'If installed via `install-agents-skills`' "$README"; then
  errors+=("README OpenClaw uninstall should describe install-agents-skills path")
fi
if ! grep -Fq '## Upgrade' "$README"; then
  errors+=("README is missing required Upgrade section")
fi
if ! grep -Fq '## Prerequisites & Troubleshooting' "$README"; then
  errors+=("README is missing required Prerequisites & Troubleshooting section")
fi
if ! grep -Fq '**Loom is:**' "$README"; then
  errors+=("README is missing Loom is/is-not boundaries")
fi
if ! grep -Fq 'docs/glossary.md' "$README"; then
  errors+=("README is missing glossary link")
fi
if grep -Fq 'one digest file' "$README"; then
  errors+=("README still describes loom-grill as digest-file output (stale since v0.24.0)")
fi
if ! grep -Fq 'omp plugin install git:github.com/zuevrs/loom --force' "$README"; then
  errors+=("README Upgrade section must document OMP --force for updates")
fi
# OMP has an early native goal-complete blocker as well as the general stop gate.
# Reject Stop-only safety claims without pinning the full prose.
if grep -Eiq 'blocks? only at (the )?(Stop|session_stop) gate' "$README"; then
  errors+=("README Safety must not describe blocking as Stop-only")
fi
if ! grep -Eiq 'goal-complete.*(Stop|session_stop)|(Stop|session_stop).*goal-complete' "$README"; then
  errors+=("README Safety must mention both OMP goal-complete and general stop enforcement")
fi
GLOSSARY_DOC="$ROOT/docs/glossary.md"
AUTHORING_DOC="$ROOT/docs/authoring.md"
if [ ! -f "$GLOSSARY_DOC" ]; then
  errors+=("docs/glossary.md is missing")
elif grep -Fwq 'enactment' "$GLOSSARY_DOC"; then
  errors+=("docs/glossary.md uses 'enactment' — normalized to 'materialization' since v0.24.6")
fi
if [ ! -f "$AUTHORING_DOC" ]; then
  errors+=("docs/authoring.md is missing")
fi
if [ ! -f "$ROOT/scripts/smoke" ]; then
  errors+=("scripts/smoke is missing")
fi
EVIDENCE_DOC="$ROOT/docs/evidence/HOST-INSTALL.md"
if [ ! -f "$EVIDENCE_DOC" ]; then
  errors+=("docs/evidence/HOST-INSTALL.md is missing")
fi
HOSTS_DOC="$ROOT/docs/hosts.md"
if [ ! -f "$HOSTS_DOC" ]; then
  errors+=("docs/hosts.md is missing")
else
  if grep -Fq 'one digest file' "$HOSTS_DOC"; then
    errors+=("docs/hosts.md still describes loom-grill as digest-file output (stale since v0.24.0)")
  fi
  if grep -Fwq 'enact' "$HOSTS_DOC"; then
    errors+=("docs/hosts.md uses 'enact' — normalized to 'materialize' since v0.24.6")
  fi
  # README is the lead (quick path), hosts.md is the depth — they must reference each other.
  if ! grep -Fq 'docs/hosts.md' "$README"; then
    errors+=("README must route to docs/hosts.md for per-host depth")
  fi
  # Install status (verified/implemented) lives ONLY in the README install table.
  # A second status surface is how the v0.22.1 impl-vs-verified drift happened.
  if grep -Eq '^\| Status \|' "$HOSTS_DOC" || grep -Fqi '| **verified**' "$HOSTS_DOC"; then
    errors+=("docs/hosts.md restates install status — README install table is the single status surface")
  fi
  # Every host in the README install table must appear in the hosts.md feature matrix.
  for host in 'Claude Code' 'Codex' 'Pi' 'OMP' 'OpenCode' 'Cursor' 'Windsurf' 'Kiro' 'Hermes' 'Cline' 'Droid' 'OpenClaw'; do
    if ! grep -Fq "$host" "$README"; then
      errors+=("README install table is missing host: $host")
    fi
    if ! grep -Fq "$host" "$HOSTS_DOC"; then
      errors+=("docs/hosts.md feature matrix is missing host: $host")
    fi
  done
fi
if ! grep -Fq 'docs/evidence/HOST-INSTALL.md' "$RELEASE_DOC"; then
  errors+=("RELEASE.md is missing host install evidence checklist link")
fi
if ! grep -Fq '## [Unreleased]' "$CHANGELOG"; then
  errors+=("CHANGELOG is missing required [Unreleased] section")
fi
if ! grep -Fq '[Unreleased]: https://github.com/zuevrs/loom/compare/' "$CHANGELOG"; then
  errors+=("CHANGELOG is missing compare link for [Unreleased]")
fi
expected_unreleased_link="[Unreleased]: https://github.com/zuevrs/loom/compare/v${pkg_version}...HEAD"
if [ -n "$pkg_version" ] && ! grep -Fq "$expected_unreleased_link" "$CHANGELOG"; then
  errors+=("CHANGELOG [Unreleased] compare link must target v${pkg_version}...HEAD")
fi
if [ -n "$pkg_version" ] && ! grep -Fq "[${pkg_version}]:" "$CHANGELOG"; then
  errors+=("CHANGELOG compare links are missing [${pkg_version}] entry")
fi
# The changelog is product-facing: distillation sources and maintainer-decision
# narrative live in the maintainer repo (ADRs), never in release notes. Scan only
# the fresh slice (Unreleased + newest release section) — history stays as written.
changelog_fresh="$(awk '/^## \[[0-9]/{c++} c==2{exit} {print}' "$CHANGELOG")"
if printf '%s' "$changelog_fresh" | grep -Eiq 'mattpocock|pocock|osmani|ponytail|caveman|humanlayer|langchain|0xcodez|reference sweep|user decision'; then
  errors+=("CHANGELOG fresh slice carries internal provenance (source names / decision narrative) — keep release notes product-facing")
fi
if ! grep -Fq '[`RELEASE.md`](RELEASE.md)' "$CONTRIBUTING_DOC"; then
  errors+=("CONTRIBUTING is missing release checklist link to RELEASE.md")
fi

# Contributing/CI parity for mandatory checks.
for cmd in \
  'npm test' \
  'bash scripts/check-drift' \
  'bash scripts/check-doc-consistency' \
  'bash scripts/check-installers' \
  'bash scripts/check-skill-template-contract'
do
  if ! grep -Fq "$cmd" "$CONTRIBUTING_DOC"; then
    errors+=("CONTRIBUTING is missing required check command: $cmd")
  fi
  if ! grep -Fq "$cmd" "$RELEASE_DOC"; then
    errors+=("RELEASE.md is missing required check command: $cmd")
  fi
done

for ci_cmd in \
  'npm test' \
  'scripts/check-drift' \
  'scripts/check-doc-consistency' \
  'scripts/check-installers' \
  'scripts/check-skill-template-contract'
do
  if ! grep -Fq "$ci_cmd" "$CHECKS_WORKFLOW"; then
    errors+=("checks.yml is missing required CI step: $ci_cmd")
  fi
done

# Template inventory and reference consistency.
template_paths=(
  "skills/loom-plan/PRD-TEMPLATE.md"
  "skills/loom-plan/ISSUE-TEMPLATE.md"
  "skills/loom-plan/PRODUCT-TEMPLATE.md"
  "skills/loom-plan/DESIGN-TEMPLATE.md"
  "skills/loom-plan/CONTEXT-FORMAT.md"
  "skills/loom-plan/ADR-FORMAT.md"
)

for rel in "${template_paths[@]}"; do
  tmpl="$ROOT/$rel"
  if [ ! -f "$tmpl" ]; then
    errors+=("missing required template file: $rel")
    continue
  fi
  if ! grep -Eq '^# ' "$tmpl"; then
    errors+=("$rel is missing top-level heading")
  fi
  if ! grep -Eq '^## ' "$tmpl"; then
    errors+=("$rel is missing section headings")
  fi
  if ! grep -Fq "$rel" "$HOSTS_DOC"; then
    errors+=("docs/hosts.md template table is missing path: $rel")
  fi
done

for plan_ref in \
  'PRD-TEMPLATE.md' \
  'ISSUE-TEMPLATE.md' \
  'PRODUCT-TEMPLATE.md' \
  'DESIGN-TEMPLATE.md' \
  'CONTEXT-FORMAT.md' \
  'ADR-FORMAT.md'
do
  if ! grep -Fq "$plan_ref" "$PLAN_SKILL"; then
    errors+=("skills/loom-plan/SKILL.md is missing template reference: $plan_ref")
  fi
done


# AGENTS managed block and loom-init managed block template must stay identical.
tmp_agents="$(mktemp)"
tmp_init="$(mktemp)"
cleanup() {
  rm -f "$tmp_agents" "$tmp_init"
}
trap cleanup EXIT

awk '
  /<!-- loom:begin version=/ {in_block=1}
  in_block {print}
  /<!-- loom:end -->/ {if (in_block) exit}
' "$AGENTS" > "$tmp_agents"

awk '
  /^```markdown$/ {fence_count++; in_block=(fence_count==1); next}
  in_block && /^```$/ {exit}
  in_block {print}
' "$INIT_SKILL" > "$tmp_init"

if [ ! -s "$tmp_agents" ] || [ ! -s "$tmp_init" ]; then
  errors+=("could not extract managed block from AGENTS.md or loom-init template")
elif ! cmp -s "$tmp_agents" "$tmp_init"; then
  errors+=("AGENTS managed block differs from skills/loom-init/SKILL.md template")
fi

# Key invariants must stay explicit across docs and pre-LLM hook.
if ! grep -Fq 'No verify digest' "$AGENTS"; then
  errors+=("AGENTS.md missing 'No verify digest' invariant")
fi
if ! grep -Fq 'No verify digest' "$INIT_SKILL"; then
  errors+=("skills/loom-init/SKILL.md missing 'No verify digest' invariant")
fi
if grep -Fq 'No verify digest' "$INVARIANTS_SRC"; then
  errors+=("hooks/invariants.cjs leaks lane-only no-verify-no-done into ordinary prompts")
fi
if ! grep -Fq 'require("./invariants.cjs")' "$PRELLM_HOOK" && ! grep -Fq "require('./invariants.cjs')" "$PRELLM_HOOK"; then
  errors+=("hooks/loom-pre-llm.cjs must require hooks/invariants.cjs")
fi


# Unified entry semantic canaries.
DISPATCHER="$ROOT/skills/loom/SKILL.md"
COMMAND="$ROOT/commands/loom.md"
GRILL_SKILL="$ROOT/skills/loom-grill/SKILL.md"
VERIFY_SKILL="$ROOT/skills/loom-verify/SKILL.md"
HERMES_YAML="$ROOT/hermes-plugin/plugin.yaml"
KIRO_AGENT="$ROOT/kiro-agent.json"
CLAUDE_PLUGIN="$ROOT/.claude-plugin/plugin.json"
for f in "$DISPATCHER" "$COMMAND"; do
  [ -f "$f" ] || errors+=("unified dispatcher target missing: ${f#$ROOT/}")
done
for phrase in 'Resolve locally' 'Plan work' 'Review ready work' 'Maintain project'; do
  grep -Fq "$phrase" "$DISPATCHER" 2>/dev/null || errors+=("dispatcher missing outcome: $phrase")
  grep -Fq "$phrase" "$README" 2>/dev/null || errors+=("README missing outcome: $phrase")
done
grep -Fq 'Explicit outcome or named target wins' "$DISPATCHER" || errors+=("dispatcher must prefer explicit route over persisted state")
grep -Fq 'Multiple candidates' "$DISPATCHER" || errors+=("dispatcher must ask on multiple resume candidates")
grep -Eq '^slash: true$' "$DISPATCHER" || errors+=("dispatcher must opt into OpenCode slash registration")
grep -Fq 'No project-file or external-state write before' "$GRILL_SKILL" || errors+=("Grill must prohibit project writes before bounded apply")
grep -Fq 'Gate 1' "$PLAN_SKILL" && grep -Fq 'Gate 2' "$PLAN_SKILL" || errors+=("Plan must expose two preview-before-write gates")
grep -Fq 'confirmed PRD without issues is valid completion' "$PLAN_SKILL" || errors+=("Plan must allow PRD-only completion")
grep -Fq 'Do not implement in the planning context' "$PLAN_SKILL" || errors+=("Plan must forbid same-context implementation")
grep -Fq 'ADR-FORMAT.md' "$GRILL_SKILL" || errors+=("Grill must use canonical ADR format")
grep -Fq 'auth/security/privacy/secrets' "$GRILL_SKILL" || errors+=("Grill must carry upward-only Verify trigger")
grep -Fq 'Spec unavailable' "$VERIFY_SKILL" || errors+=("Verify must describe review without a spec")
grep -Eq '^  - loom$' "$HERMES_YAML" || errors+=("Hermes must register exact loom command/skill")
grep -Fq 'No custom slash-command claim' "$HOSTS_DOC" || errors+=("Kiro host spelling truth missing")
grep -Fq '/loom:loom' "$README" || errors+=("Claude namespaced entry missing")
node -e 'const p=require(process.argv[1]); process.exit(Array.isArray(p.commands)&&p.commands.length===0?0:1)' "$CLAUDE_PLUGIN" || errors+=("Claude plugin commands must remain empty")
grep -Fq 'Ordinary prompts remain normal agent mode' "$AGENTS" || errors+=("managed block must scope ordinary prompts outside Loom lane")
grep -Fq 'The Loom lane begins only after explicit' "$AGENTS" || errors+=("managed block must scope ritual rules to explicit Loom entry")

if ! grep -Fq 'Report is the exit' "$ROOT/docs/unattended.md"; then errors+=("unattended keeps report exit"); fi
if ! grep -Fq 'Blockers surface in the report' "$ROOT/docs/unattended.md"; then errors+=("unattended blockers use report contract"); fi
if grep -Fq 'draft PR opened with whatever exists' "$ROOT/docs/unattended.md"; then errors+=("unattended blockers still require a PR"); fi
if grep -Eiq '(ends in (a )?pull request|reviewed PR|open PRs|PR per issue|PR opened|branch/PR)' "$ROOT/docs/unattended.md"; then errors+=("unattended current contract still carries PR-only wording"); fi
if grep -Fq 'autonomous-improvement' "$ROOT/README.md" || grep -Fq 'autonomous-improvement' "$ROOT/docs/unattended.md"; then errors+=("deferred autonomous improvement recipe must not be advertised in this release"); fi
for recipe in "$ROOT"/recipes/*.md; do
  if grep -Eq 'ends in (a )?(pull request|PR)|open a (draft )?PR|before (the )?PR|one run, one PR|PR whose title' "$recipe"; then errors+=("active recipe still requires PR delivery: ${recipe#$ROOT/}"); fi
done
if ! grep -Fq 'Loom does not require PR creation' "$ROOT/skills/loom-implement/SKILL.md"; then errors+=("implement keeps PR optional"); fi

if [ ${#errors[@]} -eq 0 ]; then
  echo '{"status":"clean","message":"Docs consistency checks passed"}'
  exit 0
fi

echo "{"
echo '  "status": "drift",'
echo '  "errors": ['
for i in "${!errors[@]}"; do
  comma=","
  [ "$i" -eq "$((${#errors[@]} - 1))" ] && comma=""
  echo "    \"${errors[$i]}\"$comma"
done
echo '  ]'
echo "}"
exit 1
