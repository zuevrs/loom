#!/usr/bin/env bash
# loom: installer canary — validates install script presence and contracts
# Exit: 0 clean, 1 drift detected
set -euo pipefail

ROOT="${1:-$(cd "$(dirname "$0")/.." && pwd)}"
errors=()

# Node installer is the single source of install logic; bash scripts are thin wrappers.
installer="$ROOT/scripts/install.mjs"
if [ ! -f "$installer" ]; then
  errors+=("missing installer: scripts/install.mjs")
else
  if ! node --check "$installer" 2>/dev/null; then
    errors+=("scripts/install.mjs has invalid syntax")
  fi
  for contract in '".agents", "skills"' '".cursor", "hooks.json"' '".codeium", "windsurf", "skills"' '".kiro", "skills"' '".kiro", "agents"' 'stop-gate-logic'; do
    if ! grep -Fq "$contract" "$installer"; then
      errors+=("install.mjs target contract drifted: $contract")
    fi
  done
fi

wrappers=(
  "scripts/install-cursor:--cursor"
  "scripts/install-windsurf:--windsurf"
  "scripts/install-kiro:--kiro"
  "scripts/install-agents-skills:--agents"
)
for pair in "${wrappers[@]}"; do
  rel="${pair%%:*}"
  flag="${pair##*:}"
  file="$ROOT/$rel"
  if [ ! -f "$file" ]; then
    errors+=("missing installer wrapper: $rel")
    continue
  fi
  if [ ! -x "$file" ]; then
    errors+=("installer wrapper is not executable: $rel")
  fi
  if ! bash -n "$file"; then
    errors+=("installer wrapper has invalid bash syntax: $rel")
  fi
  if ! grep -Fq "install.mjs\" $flag" "$file"; then
    errors+=("$rel must delegate to install.mjs $flag")
  fi
done
if ! grep -Fq '"Stop"' "$ROOT/hooks/claude-codex-hooks.json" 2>/dev/null; then
  errors+=("claude-codex-hooks.json missing Stop enforcement hook")
fi
if grep -Fq 'bash' "$ROOT/hooks/claude-codex-hooks.json" 2>/dev/null; then
  errors+=("claude-codex-hooks.json must not depend on bash (hooks are pure Node)")
fi

# Enforcement artifacts exist and are non-empty
if [ ! -f "$ROOT/hooks/stop-gate-logic.cjs" ]; then
  errors+=("hooks/stop-gate-logic.cjs missing")
fi
if ! ls "$ROOT/rules/"*.md >/dev/null 2>&1; then
  errors+=("rules/ has no .md files (OMP TTSR convention)")
fi
if ! ls "$ROOT/agents/"*.md >/dev/null 2>&1; then
  errors+=("agents/ has no .md files (OMP custom agent convention)")
fi
if ! grep -Fq 'session_stop' "$ROOT/omp-extension.mjs" 2>/dev/null; then
  errors+=("omp-extension.mjs missing session_stop verify gate")
fi
if [ ! -f "$ROOT/hooks/stop-gate-logic.cjs" ]; then
  errors+=("hooks/stop-gate-logic.cjs missing (shared verify gate)")
fi

if [ ${#errors[@]} -eq 0 ]; then
  echo '{"status":"clean","message":"Installer checks passed"}'
  exit 0
fi

echo "{"
echo '  "status": "drift",'
echo '  "errors": ['
for i in "${!errors[@]}"; do
  comma=","
  [ "$i" -eq "$((${#errors[@]} - 1))" ] && comma=""
  echo "    \"${errors[$i]}\"$comma"
done
echo '  ]'
echo "}"
exit 1
