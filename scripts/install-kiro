#!/usr/bin/env bash
# loom: install agent + skills for Kiro CLI
# 1. Creates symlinks in ~/.kiro/skills/ for all Loom skill directories
# 2. Copies loom agent config to ~/.kiro/agents/
set -euo pipefail

LOOM_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$LOOM_ROOT/skills"
SKILLS_TARGET="$HOME/.kiro/skills"
AGENT_TARGET="$HOME/.kiro/agents"

# --- Skills ---
echo "Kiro skills:"
mkdir -p "$SKILLS_TARGET"

installed=0
for skill_dir in "$SKILLS_DIR"/*/; do
  [ -f "${skill_dir}SKILL.md" ] || continue
  skill_name=$(basename "$skill_dir")
  target="$SKILLS_TARGET/$skill_name"

  if [ -L "$target" ]; then
    existing=$(readlink "$target")
    if [ "$existing" = "${skill_dir%/}" ]; then
      echo "  ✓ $skill_name (already linked)"
      installed=$((installed + 1))
      continue
    fi
    echo "  ⚠ $skill_name: symlink exists → $existing (skipping)"
    continue
  fi

  if [ -e "$target" ]; then
    echo "  ⚠ $skill_name: exists (skipping)"
    continue
  fi

  ln -s "${skill_dir%/}" "$target"
  echo "  ✓ $skill_name"
  installed=$((installed + 1))
done

echo "  $installed skills linked"
echo ""

# --- Agent config ---
echo "Kiro agent:"
mkdir -p "$AGENT_TARGET"

AGENT_FILE="$AGENT_TARGET/loom.json"
if [ -L "$AGENT_FILE" ]; then
  existing=$(readlink "$AGENT_FILE")
  if [ "$existing" = "$LOOM_ROOT/kiro-agent.json" ]; then
    echo "  ✓ loom agent (already linked)"
  else
    echo "  ⚠ loom.json: symlink exists → $existing (skipping)"
  fi
elif [ -f "$AGENT_FILE" ]; then
  echo "  ⚠ loom.json exists (not a symlink — skipping)"
else
  ln -s "$LOOM_ROOT/kiro-agent.json" "$AGENT_FILE"
  echo "  ✓ linked loom.json → $AGENT_FILE"
fi

echo ""
echo "Done. Use 'kiro --agent loom' or switch via /agent loom."
