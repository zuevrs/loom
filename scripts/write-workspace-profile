#!/usr/bin/env node
// loom: validated atomic workspace profile writer; caller owns confirmation.
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { createRequire } from "node:module";
const { writeWorkspaceProfile } = createRequire(import.meta.url)("../hooks/workspace.cjs");
const [root, profileFile] = process.argv.slice(2);
if (!root || !profileFile) {
  console.error("usage: write-workspace-profile <workspace-root> <profile.json>");
  process.exit(2);
}
try {
  const result = writeWorkspaceProfile(JSON.parse(readFileSync(resolve(profileFile), "utf8")), root);
  process.stdout.write(`${JSON.stringify({ changed: result.changed, profile_path: result.profilePath, backup_path: result.backupPath })}\n`);
} catch (error) {
  console.error(`workspace profile write failed: ${error.message}`);
  process.exit(1);
}
